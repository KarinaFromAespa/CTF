          "cookies": [],
          "content": {
            "size": 6079,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <title>Northstar Notes</title>\r\n  <link rel=\"stylesheet\" href=\"/css/challenge-style.css\">\r\n</head>\r\n<body>\r\n\r\n  <header class=\"topbar\">\r\n    <nav>\r\n      <a href=\"/\" class=\"brand\">\r\n        <svg class=\"brand-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"/><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"/></svg>\r\n        Northstar Notes\r\n      </a>\r\n      <div class=\"nav-actions\">\r\n        <a href=\"/#notes\" class=\"nav-link\">Library</a>\r\n        <a href=\"/#my-notes\" class=\"nav-link\">Workspace</a>\r\n        <a href=\"/#create\" class=\"nav-link\">Compose</a>\r\n        <a href=\"/#settings\" class=\"nav-link\">Preferences</a>\r\n      </div>\r\n    </nav>\r\n  </header>\r\n\r\n  <main>\r\n\r\n    \r\n\r\n    <section class=\"hero\">\r\n      <div class=\"hero-glow\"></div>\r\n      <p class=\"hero-tag\">Team docs that stay out of the way</p>\r\n      <h1>Northstar <span class=\"accent\">Notes</span></h1>\r\n      <p class=\"hero-sub\">A lightweight writing space for internal updates, draft memos, release notes, and quick knowledge sharing.</p>\r\n      <div class=\"hero-actions\">\r\n        <a href=\"#create\" class=\"btn btn-primary\">New note</a>\r\n        <a href=\"#notes\" class=\"btn btn-ghost\">Browse library</a>\r\n      </div>\r\n    </section>\r\n\r\n    <section class=\"section section-tight\">\r\n      <div class=\"section-heading\">\r\n        <h2>Search the library</h2>\r\n        <p>Quickly jump to public notes and reference pages.</p>\r\n      </div>\r\n      <div class=\"search-shell\">\r\n        <input id=\"search-input\" type=\"search\" placeholder=\"Search notes, guides, and docs\">\r\n        <div id=\"search-results\" class=\"search-results\"></div>\r\n      </div>\r\n    </section>\r\n\r\n    <section id=\"notes\" class=\"section\">\r\n      <div class=\"section-heading\">\r\n        <h2>Published notes</h2>\r\n        <p>Shared pages available to everyone in the workspace.</p>\r\n      </div>\r\n      <div class=\"notes-grid\">\r\n        \r\n          <a href=\"/note/welcome\" class=\"note-card\">\r\n            <h3>Welcome to Northstar Notes</h3>\r\n            <span class=\"note-card-author\">system</span>\r\n          </a>\r\n        \r\n          <a href=\"/note/guide\" class=\"note-card\">\r\n            <h3>Writing Guide</h3>\r\n            <span class=\"note-card-author\">system</span>\r\n          </a>\r\n        \r\n        \r\n      </div>\r\n    </section>\r\n\r\n    <section id=\"my-notes\" class=\"section\">\r\n      <div class=\"section-heading\">\r\n        <h2>Your drafts</h2>\r\n        <p>Recently created notes saved in this browser.</p>\r\n      </div>\r\n      <div id=\"private-notes-grid\" class=\"notes-grid\">\r\n        <p class=\"empty\" id=\"private-notes-empty\">No local drafts yet. Create one below to get started.</p>\r\n      </div>\r\n    </section>\r\n\r\n    <section id=\"create\" class=\"section\">\r\n      <div class=\"section-heading\">\r\n        <h2>Write a note</h2>\r\n        <p>Rich formatting is supported for pasted content, embeds, tables, and snippets.</p>\r\n      </div>\r\n      <form id=\"create-form\" class=\"card-form\">\r\n        <div class=\"field\">\r\n          <label for=\"note-title\">Title</label>\r\n          <input type=\"text\" id=\"note-title\" name=\"title\" placeholder=\"Quarterly update\" maxlength=\"200\" required>\r\n        </div>\r\n        <div class=\"field\">\r\n          <label for=\"note-content\">Content <span class=\"field-hint\">Rich content supported</span></label>\r\n          <textarea id=\"note-content\" name=\"content\" rows=\"8\"\r\n                    placeholder=\"<h2>Release notes</h2>&#10;<p>Share updates, highlights, and formatted details.</p>\"\r\n                    required></textarea>\r\n        </div>\r\n        <button type=\"submit\" class=\"btn btn-primary\">Publish</button>\r\n        <div id=\"create-result\"></div>\r\n      </form>\r\n    </section>\r\n\r\n    <section id=\"settings\" class=\"section\">\r\n      <div class=\"section-heading\">\r\n        <h2>Preferences</h2>\r\n        <p>Adjust your writing environment for comfort and readability.</p>\r\n      </div>\r\n      <form id=\"settings-form\" class=\"card-form\">\r\n        <div class=\"field-row\">\r\n          <div class=\"field\">\r\n            <label for=\"s-theme\">Theme</label>\r\n            <select id=\"s-theme\" name=\"theme\">\r\n              <option value=\"dark\" selected>Dark</option>\r\n              <option value=\"light\">Light</option>\r\n            </select>\r\n          </div>\r\n          <div class=\"field\">\r\n            <label for=\"s-fontsize\">Font size</label>\r\n            <input type=\"number\" id=\"s-fontsize\" name=\"fontSize\" value=\"14\" min=\"10\" max=\"24\">\r\n          </div>\r\n          <div class=\"field\">\r\n            <label for=\"s-lang\">Language</label>\r\n            <select id=\"s-lang\" name=\"language\">\r\n              <option value=\"en\">English</option>\r\n              <option value=\"fr\">Fran&ccedil;ais</option>\r\n              <option value=\"de\">Deutsch</option>\r\n            </select>\r\n          </div>\r\n          <div class=\"field\">\r\n            <label for=\"s-layout\">Default layout</label>\r\n            <select id=\"s-layout\" name=\"defaultLayout\">\r\n              <option value=\"summary\">Summary</option>\r\n              <option value=\"print\">Print</option>\r\n              <option value=\"compact\">Compact</option>\r\n            </select>\r\n          </div>\r\n        </div>\r\n        <button type=\"submit\" class=\"btn btn-ghost\">Save changes</button>\r\n        <div id=\"settings-meta\" class=\"settings-meta\">Reader presets sync to this account automatically when they are created.</div>\r\n        <div id=\"settings-result\"></div>\r\n      </form>\r\n    </section>\r\n\r\n  </main>\r\n\r\n  <footer>\r\n    <p>Northstar Notes &copy; 2026</p>\r\n  </footer>\r\n\r\n  <script nonce=\"cTcEZ/xc/Tgxrh9ZbrWZzA==\">\r\n    window.__APP_INIT__ = {\"theme\":\"dark\"};\r\n  </script>\r\n  <script nonce=\"cTcEZ/xc/Tgxrh9ZbrWZzA==\" src=\"/js/vendor/purify.min.js\"></script>\r\n  <script nonce=\"cTcEZ/xc/Tgxrh9ZbrWZzA==\" src=\"/js/app.js\"></script>\r\n</body>\r\n</html>\r\n"
          },
