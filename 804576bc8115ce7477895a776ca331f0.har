            "size": 11329,
            "mimeType": "text/css",
            "text": "@import url(\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap\");\r\n\r\n:root{\r\n  --bg:#f5f7fb;\r\n  --bg2:#eef2f8;\r\n  --card:rgba(255,255,255,.94);\r\n  --card-hover:rgba(255,255,255,.99);\r\n  --text:#152033;\r\n  --text2:#4d5b74;\r\n  --muted:#72809a;\r\n  --accent:#2563eb;\r\n  --accent-h:#1d4ed8;\r\n  --accent-glow:rgba(37,99,235,.18);\r\n  --accent-soft:rgba(37,99,235,.10);\r\n  --border:rgba(15,23,42,.08);\r\n  --border-h:rgba(37,99,235,.22);\r\n  --input:rgba(248,250,252,.95);\r\n  --r:14px;\r\n  --r-sm:8px;\r\n  --font:\"Inter\",-apple-system,system-ui,sans-serif;\r\n  --mono:\"JetBrains Mono\",\"Fira Code\",monospace;\r\n  --ease:cubic-bezier(.4,0,.2,1);\r\n}\r\n\r\n*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}\r\nhtml{scroll-behavior:smooth}\r\n\r\nbody{\r\n  min-height:100dvh;\r\n  font-family:var(--font);\r\n  line-height:1.65;\r\n  color:var(--text);\r\n  background:\r\n    radial-gradient(ellipse 80% 45% at 50% -10%, rgba(37,99,235,.10), transparent 70%),\r\n    linear-gradient(180deg, rgba(255,255,255,.96), rgba(245,247,251,1));\r\n  -webkit-font-smoothing:antialiased;\r\n}\r\n\r\n::selection{background:rgba(37,99,235,.18);color:var(--text)}\r\n\r\na{color:var(--accent);text-decoration:none;transition:color .15s var(--ease)}\r\na:hover{color:var(--accent-h)}\r\n\r\ncode,pre,kbd,samp{font-family:var(--mono);font-size:.88em}\r\ncode{background:rgba(37,99,235,.08);padding:.12em .4em;border-radius:3px;color:var(--accent-h)}\r\npre{background:var(--bg2);padding:1rem 1.2rem;border-radius:var(--r-sm);overflow-x:auto;border:1px solid var(--border)}\r\npre code{background:none;padding:0}\r\n\r\n.topbar{\r\n  position:sticky;\r\n  top:0;\r\n  z-index:100;\r\n  background:rgba(255,255,255,.78);\r\n  backdrop-filter:blur(16px) saturate(160%);\r\n  border-bottom:1px solid var(--border);\r\n}\r\n\r\n.topbar nav{\r\n  max-width:1100px;\r\n  margin:0 auto;\r\n  padding:.8rem 1.5rem;\r\n  display:flex;\r\n  align-items:center;\r\n  justify-content:space-between;\r\n}\r\n\r\n.brand{\r\n  display:flex;\r\n  align-items:center;\r\n  gap:.55rem;\r\n  font-size:1rem;\r\n  font-weight:700;\r\n  letter-spacing:-.02em;\r\n  color:var(--text);\r\n}\r\n\r\n.brand:hover{color:var(--accent)}\r\n.brand-icon{width:20px;height:20px;color:var(--accent)}\r\n\r\n.nav-actions{display:flex;gap:1.4rem}\r\n.nav-link{font-size:.88rem;font-weight:600;color:var(--muted)}\r\n.nav-link:hover{color:var(--accent)}\r\n\r\n.hero{\r\n  position:relative;\r\n  max-width:1100px;\r\n  margin:0 auto;\r\n  padding:5.5rem 1.5rem 3rem;\r\n  text-align:center;\r\n  overflow:hidden;\r\n}\r\n\r\n.hero-glow{\r\n  position:absolute;\r\n  top:-80px;\r\n  left:50%;\r\n  transform:translateX(-50%);\r\n  width:600px;\r\n  height:600px;\r\n  background:radial-gradient(circle,rgba(37,99,235,.12) 0%,transparent 65%);\r\n  pointer-events:none;\r\n}\r\n\r\n.hero-tag{\r\n  margin-bottom:1rem;\r\n  color:var(--accent);\r\n  font-size:.9rem;\r\n  font-weight:600;\r\n}\r\n\r\n.hero h1{\r\n  margin-bottom:.8rem;\r\n  font-size:clamp(3rem,8vw,4.8rem);\r\n  font-weight:800;\r\n  line-height:1;\r\n  letter-spacing:-.04em;\r\n}\r\n\r\n.hero h1 .accent{color:var(--accent)}\r\n\r\n.hero-sub{\r\n  max-width:620px;\r\n  margin:0 auto 2rem;\r\n  color:var(--text2);\r\n  font-size:1.02rem;\r\n  line-height:1.7;\r\n}\r\n\r\n.hero-actions{display:flex;gap:.8rem;justify-content:center;flex-wrap:wrap}\r\n\r\n.section{\r\n  max-width:1100px;\r\n  margin:0 auto;\r\n  padding:2.5rem 1.5rem;\r\n}\r\n\r\n.section-tight{padding-top:1rem}\r\n\r\n.section-heading{margin-bottom:1.2rem}\r\n.section-heading h2{\r\n  margin-bottom:.3rem;\r\n  font-size:1.35rem;\r\n  letter-spacing:-.03em;\r\n}\r\n.section-heading p{color:var(--text2);font-size:.94rem}\r\n\r\n.search-shell{\r\n  background:var(--card);\r\n  border:1px solid var(--border);\r\n  border-radius:var(--r);\r\n  padding:1rem;\r\n  box-shadow:0 12px 30px rgba(15,23,42,.05);\r\n}\r\n\r\n.search-results{\r\n  display:grid;\r\n  gap:.65rem;\r\n  margin-top:.9rem;\r\n}\r\n\r\n.search-result{\r\n  display:block;\r\n  background:#fff;\r\n  border:1px solid var(--border);\r\n  border-radius:10px;\r\n  padding:.8rem .95rem;\r\n  color:var(--text);\r\n}\r\n\r\n.search-result:hover{\r\n  border-color:var(--border-h);\r\n  box-shadow:0 8px 18px rgba(37,99,235,.08);\r\n}\r\n\r\n.no-results{\r\n  color:var(--muted);\r\n  font-size:.88rem;\r\n  padding:.25rem 0;\r\n}\r\n\r\n.notes-grid{\r\n  display:grid;\r\n  grid-template-columns:repeat(auto-fill,minmax(260px,1fr));\r\n  gap:.8rem;\r\n}\r\n\r\n.note-card{\r\n  display:block;\r\n  padding:1.1rem 1.3rem;\r\n  background:var(--card);\r\n  border:1px solid var(--border);\r\n  border-radius:var(--r);\r\n  box-shadow:0 8px 30px rgba(15,23,42,.04);\r\n  transition:all .2s var(--ease);\r\n}\r\n\r\n.note-card:hover{\r\n  background:var(--card-hover);\r\n  border-color:var(--border-h);\r\n  transform:translateY(-2px);\r\n  box-shadow:0 18px 40px rgba(37,99,235,.08);\r\n}\r\n\r\n.note-card h3{\r\n  margin-bottom:.25rem;\r\n  font-size:.95rem;\r\n  font-weight:600;\r\n  color:var(--text);\r\n}\r\n\r\n.note-card-author{font-size:.78rem;color:var(--muted)}\r\n.empty{color:var(--muted);font-size:.88rem}\r\n\r\n.card-form{\r\n  background:var(--card);\r\n  border:1px solid var(--border);\r\n  border-radius:var(--r);\r\n  padding:1.6rem 1.8rem;\r\n  box-shadow:0 12px 36px rgba(15,23,42,.05);\r\n}\r\n\r\n.field{margin-bottom:1.1rem}\r\n.field label{\r\n  display:block;\r\n  margin-bottom:.35rem;\r\n  color:var(--muted);\r\n  font-size:.84rem;\r\n  font-weight:600;\r\n}\r\n\r\n.field-hint{font-weight:400;color:var(--muted)}\r\n\r\n.field-row{\r\n  display:grid;\r\n  grid-template-columns:repeat(auto-fit,minmax(160px,1fr));\r\n  gap:.8rem;\r\n  margin-bottom:1.1rem;\r\n}\r\n\r\ninput[type=\"text\"],input[type=\"number\"],input[type=\"url\"],input[type=\"search\"],textarea,select{\r\n  width:100%;\r\n  padding:.72rem .9rem;\r\n  font-family:var(--font);\r\n  font-size:.92rem;\r\n  color:var(--text);\r\n  background:var(--input);\r\n  border:1px solid var(--border);\r\n  border-radius:var(--r-sm);\r\n  outline:none;\r\n  transition:border-color .15s var(--ease),box-shadow .15s var(--ease);\r\n}\r\n\r\ninput:focus,textarea:focus,select:focus{\r\n  border-color:var(--accent);\r\n  box-shadow:0 0 0 3px var(--accent-soft);\r\n}\r\n\r\ntextarea{\r\n  resize:vertical;\r\n  font-family:var(--mono);\r\n  font-size:.84rem;\r\n  line-height:1.55;\r\n}\r\n\r\nselect{cursor:pointer}\r\n\r\n.btn{\r\n  display:inline-flex;\r\n  align-items:center;\r\n  justify-content:center;\r\n  gap:.45rem;\r\n  padding:.72rem 1.6rem;\r\n  border:none;\r\n  border-radius:var(--r-sm);\r\n  font-size:.88rem;\r\n  font-weight:600;\r\n  cursor:pointer;\r\n  text-decoration:none;\r\n  transition:all .18s var(--ease);\r\n}\r\n\r\n.btn:disabled{opacity:.45;cursor:not-allowed}\r\n\r\n.btn-primary{\r\n  color:#fff;\r\n  background:var(--accent);\r\n  border:1px solid var(--accent);\r\n}\r\n\r\n.btn-primary:hover:not(:disabled){\r\n  background:var(--accent-h);\r\n  box-shadow:0 0 24px var(--accent-glow);\r\n  transform:translateY(-1px);\r\n}\r\n\r\n.btn-ghost{\r\n  color:var(--text2);\r\n  background:transparent;\r\n  border:1px solid var(--border);\r\n}\r\n\r\n.btn-ghost:hover:not(:disabled){\r\n  color:var(--text);\r\n  background:rgba(255,255,255,.5);\r\n  border-color:var(--border-h);\r\n}\r\n\r\n.btn-danger{\r\n  color:var(--accent-h);\r\n  background:rgba(37,99,235,.08);\r\n  border:1px solid rgba(37,99,235,.16);\r\n}\r\n\r\n.btn-danger:hover:not(:disabled){\r\n  color:#fff;\r\n  background:var(--accent);\r\n  box-shadow:0 0 16px var(--accent-glow);\r\n}\r\n\r\n.btn-sm{padding:.5rem 1rem;font-size:.78rem}\r\n\r\n.note-main{max-width:820px;margin:0 auto;padding:2rem 1.5rem 4rem}\r\n\r\n.note-article{\r\n  overflow:hidden;\r\n  background:var(--card);\r\n  border:1px solid var(--border);\r\n  border-radius:var(--r);\r\n  box-shadow:0 16px 48px rgba(15,23,42,.06);\r\n}\r\n\r\n.note-head{\r\n  padding:1.8rem 2rem 1.4rem;\r\n  border-bottom:1px solid var(--border);\r\n}\r\n\r\n.note-head-meta{\r\n  display:flex;\r\n  align-items:center;\r\n  gap:.5rem;\r\n  margin-bottom:.55rem;\r\n  color:var(--muted);\r\n  font-size:.72rem;\r\n}\r\n\r\n.dot{color:rgba(37,99,235,.2)}\r\n.note-head-author{color:var(--accent)}\r\n\r\n.note-head h1{\r\n  font-size:1.6rem;\r\n  font-weight:700;\r\n  letter-spacing:.02em;\r\n}\r\n\r\n.view-switcher{\r\n  display:flex;\r\n  flex-wrap:wrap;\r\n  gap:.55rem;\r\n  margin-top:1rem;\r\n}\r\n\r\n.view-pill{\r\n  display:inline-flex;\r\n  align-items:center;\r\n  padding:.38rem .8rem;\r\n  color:var(--text2);\r\n  background:rgba(255,255,255,.72);\r\n  border:1px solid var(--border);\r\n  border-radius:999px;\r\n  font-size:.8rem;\r\n  font-weight:600;\r\n}\r\n\r\n.view-pill:hover{color:var(--accent);border-color:var(--border-h)}\r\n\r\n.view-pill-active{\r\n  color:var(--accent);\r\n  background:var(--accent-soft);\r\n  border-color:rgba(37,99,235,.22);\r\n}\r\n\r\n.note-body{\r\n  min-height:100px;\r\n  padding:1.8rem 2rem;\r\n  line-height:1.8;\r\n  font-size:.98rem;\r\n}\r\n\r\n.note-body h1,.note-body h2,.note-body h3,\r\n.note-body h4,.note-body h5,.note-body h6{\r\n  margin-top:1.4rem;\r\n  margin-bottom:.5rem;\r\n  color:var(--text);\r\n}\r\n\r\n.note-body p{margin-bottom:.9rem}\r\n.note-body ul,.note-body ol{margin-bottom:.9rem;padding-left:1.4rem}\r\n.note-body li{margin-bottom:.25rem}\r\n\r\n.note-body blockquote{\r\n  margin:1rem 0;\r\n  padding:.6rem 1.1rem;\r\n  color:var(--text2);\r\n  background:var(--accent-soft);\r\n  border-left:3px solid var(--accent);\r\n  border-radius:0 var(--r-sm) var(--r-sm) 0;\r\n}\r\n\r\n.note-body img{max-width:100%;height:auto;border-radius:var(--r-sm);margin:.8rem 0}\r\n.note-body table{width:100%;border-collapse:collapse;margin:.8rem 0}\r\n.note-body th,.note-body td{border:1px solid var(--border);padding:.45rem .7rem;text-align:left}\r\n.note-body th{background:var(--bg2);font-weight:600;font-size:.88rem}\r\n.note-body a{color:var(--accent);border-bottom:1px dashed rgba(37,99,235,.3)}\r\n.note-body a:hover{border-bottom-style:solid}\r\n\r\n.note-loading{\r\n  display:flex;\r\n  align-items:center;\r\n  gap:.6rem;\r\n  padding:.5rem 0;\r\n  color:var(--muted);\r\n  font-size:.88rem;\r\n}\r\n\r\n.spinner{\r\n  width:16px;\r\n  height:16px;\r\n  border:2px solid var(--border);\r\n  border-top-color:var(--accent);\r\n  border-radius:50%;\r\n  animation:spin .55s linear infinite;\r\n}\r\n\r\n@keyframes spin{to{transform:rotate(360deg)}}\r\n\r\n.note-actions{\r\n  display:flex;\r\n  align-items:center;\r\n  justify-content:space-between;\r\n  gap:.8rem;\r\n  margin-top:1.2rem;\r\n}\r\n\r\n.toast{\r\n  max-width:1100px;\r\n  margin:1rem auto;\r\n  padding:.8rem 1.2rem;\r\n  font-size:.88rem;\r\n  border-radius:var(--r-sm);\r\n}\r\n\r\n.toast-error{\r\n  color:#b91c1c;\r\n  background:rgba(239,68,68,.08);\r\n  border:1px solid rgba(239,68,68,.16);\r\n}\r\n\r\n.result-msg{\r\n  display:none;\r\n  margin-top:.8rem;\r\n  padding:.6rem .9rem;\r\n  font-size:.84rem;\r\n  border-radius:var(--r-sm);\r\n}\r\n\r\n.result-success{\r\n  color:#15803d;\r\n  background:rgba(34,197,94,.08);\r\n  border:1px solid rgba(34,197,94,.18);\r\n}\r\n\r\n.result-error{\r\n  color:#b91c1c;\r\n  background:rgba(239,68,68,.08);\r\n  border:1px solid rgba(239,68,68,.16);\r\n}\r\n\r\n.result-msg a{font-weight:600}\r\n.widget-container{margin-top:.8rem;min-height:0}\r\n.settings-meta{\r\n  margin-top:.85rem;\r\n  color:var(--muted);\r\n  font-size:.84rem;\r\n}\r\n\r\nfooter{\r\n  max-width:1100px;\r\n  margin:0 auto;\r\n  padding:2.5rem 1.5rem;\r\n  text-align:center;\r\n  color:var(--muted);\r\n  font-size:.8rem;\r\n  border-top:1px solid var(--border);\r\n}\r\n\r\n::-webkit-scrollbar{width:6px;height:6px}\r\n::-webkit-scrollbar-track{background:var(--bg)}\r\n::-webkit-scrollbar-thumb{background:rgba(37,99,235,.14);border-radius:3px}\r\n::-webkit-scrollbar-thumb:hover{background:var(--muted)}\r\n\r\n@media(max-width:640px){\r\n  .hero{padding:4rem 1.2rem 3rem}\r\n  .hero h1{font-size:2.6rem}\r\n  .card-form{padding:1.2rem}\r\n  .note-head,.note-body{padding:1.2rem}\r\n  .note-actions{flex-direction:column}\r\n  .nav-actions{gap:.8rem}\r\n}\r\n"
